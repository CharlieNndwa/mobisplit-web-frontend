{
  "expo": {
    "name": "MobiSplit-app",
    "slug": "MobiSplit-app",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/favicon.png",
    "scheme": "mobisplitapp",
    "userInterfaceStyle": "automatic",
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.charlie.mobisplit",
      "infoPlist": {
        "ITSAppUsesNonExemptEncryption": false
      }
    },
    "android": {
      "package": "com.charlie.mobisplit",
      "googleServicesFile": "./google-services.json",
      "adaptiveIcon": {
        "foregroundImage": "./assets/images/adaptive-icon.png",
        "backgroundColor": "#ffffff"
      }
    },
    "extra": {
      "eas": {
        "projectId": "db4d267a-c1c5-4da3-a8f4-56bc6528c4ff"
      }
    },
    "plugins": [
      "expo-router",
      "expo-video",
      "expo-secure-store",
      "@react-native-google-signin/google-signin",
      [
        "expo-splash-screen",
        {
          "image": "./assets/images/favicon.png",
          "resizeMode": "contain",
          "backgroundColor": "#ffffff"
        }
      ],
      [
        "./node_modules/react-native-google-mobile-ads/app.plugin.js",
        {
          "androidAppId": "ca-app-pub-6268822114678527~1297375618",
          "iosAppId": "ca-app-pub-3940256099942544~1458002511"
        }
      ],
      [
        "expo-build-properties",
        {
          "android": {
            "ndkVersion": "26.1.10909408",
            "packagingOptions": {
              "pickFirst": [
                "**/libcrypto.so",
                "**/libssl.so"
              ]
            }
          }
        }
      ]
    ]
  }
}
